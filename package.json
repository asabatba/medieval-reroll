{
  "name": "medieval-reroll",
  "version": "1.0.0",
  "description": "A deterministic history engine that resolves a whole medieval village genealogy from a single address, and lets you browse any life in it.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "lint": "biome lint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "happy-dom": "^20.11.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
